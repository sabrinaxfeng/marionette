{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "task_id",
    "decision",
    "metric_name",
    "metric_value",
    "baseline_value",
    "delta",
    "summary",
    "diagnosis",
    "next_task",
    "files_changed",
    "escalation_reason"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": ["accept", "reject", "rerun", "diagnose", "escalate"],
      "description": "accept=merge and continue, reject=revert, rerun=retry same task, diagnose=run diagnostic then decide, escalate=hand back to Claude"
    },
    "metric_name": {
      "type": ["string", "null"]
    },
    "metric_value": {
      "type": ["number", "null"]
    },
    "baseline_value": {
      "type": ["number", "null"]
    },
    "delta": {
      "type": ["number", "null"]
    },
    "summary": {
      "type": "string",
      "description": "What happened and why this decision"
    },
    "diagnosis": {
      "type": ["string", "null"],
      "description": "Root cause analysis if decision is reject/diagnose/escalate"
    },
    "next_task": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "objective", "hypothesis", "instructions", "validation_command", "files_to_read", "acceptance_gate", "timeout_minutes", "source"],
          "properties": {
            "task_id": {"type": "string"},
            "objective": {"type": "string"},
            "hypothesis": {"type": "string"},
            "instructions": {"type": "array", "items": {"type": "string"}},
            "validation_command": {"type": ["string", "null"]},
            "files_to_read": {"type": "array", "items": {"type": "string"}},
            "acceptance_gate": {"type": "string"},
            "timeout_minutes": {"type": "integer"},
            "source": {"type": "string", "enum": ["claude", "codex_analyst"]}
          }
        }
      ],
      "description": "If decision is accept/rerun/diagnose, the next codex_task to queue (conforms to codex_task schema)"
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "escalation_reason": {
      "type": ["string", "null"],
      "description": "Why Claude needs to review, if decision is escalate"
    }
  }
}
